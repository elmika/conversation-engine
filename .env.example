# Required for OpenAI Responses API
OPENAI_API_KEY=sk-...

# Optional: override defaults
# MAX_INPUT_CHARS=32000
# MAX_OUTPUT_TOKENS=4096
# REQUEST_TIMEOUT_S=60
# MAX_RETRIES=2
# RETRY_BACKOFF_S=1.0
# DEFAULT_PROMPT_SLUG=default
# DATABASE_URL=sqlite+aiosqlite:///./data/chat.db

# History capping (prevents context overflow and cost explosion)
# MAX_HISTORY_TURNS=20        # Max conversation turns to include (10 exchanges)
# MAX_HISTORY_TOKENS=100000   # Max tokens in history (~75% of 128K context for gpt-4.1-mini)
